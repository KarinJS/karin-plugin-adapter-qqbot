{
  "name": "@karinjs/adapter-qqbot",
  "version": "1.3.1",
  "description": "karin plugin adapter for qqbot",
  "homepage": "https://github.com/KarinJS/karin-plugin-adapter-qqbot",
  "bugs": {
    "url": "https://github.com/KarinJS/karin-plugin-adapter-qqbot/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KarinJS/karin-plugin-adapter-qqbot.git"
  },
  "author": "shijin",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsdown",
    "dev": "tsx src/app.ts",
    "karin": "karin",
    "pub": "npm publish --access public",
    "sort": "npx sort-package-json"
  },
  "dependencies": {
    "@karinjs/geturls": "^1.0.2",
    "form-data": "^4.0.5",
    "image-size": "^2.0.2",
    "qrcode": "^1.5.4",
    "silk-wasm": "^3.7.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/form-data": "^2.5.2",
    "@types/node": "^24.12.4",
    "@types/qrcode": "^1.5.6",
    "eslint": "^10.3.0",
    "neostandard": "^0.13.0",
    "node-karin": "^1.15.5",
    "tsdown": "^0.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "karin": {
    "main": "src/index.ts",
    "apps": [
      "dist/apps"
    ],
    "ts-apps": [
      "src/apps"
    ],
    "static": [
      "resources"
    ],
    "files": [
      "config",
      "data",
      "resources"
    ],
    "ts-web": "src/web.config.ts",
    "web": "dist/web.config.mjs"
  }
}