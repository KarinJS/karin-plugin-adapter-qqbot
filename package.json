{
  "name": "@karinjs/adapter-qqbot",
  "version": "2.2.1",
  "description": "karin adapter for QQ Official Bot (2.0)",
  "homepage": "https://github.com/KarinJS/karin-plugin-adapter-qqbot",
  "bugs": {
    "url": "https://github.com/KarinJS/karin-plugin-adapter-qqbot/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KarinJS/karin-plugin-adapter-qqbot.git"
  },
  "author": "shijin",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsdown",
    "dev": "tsx watch --include \"src/**/*.ts\" src/app.ts",
    "karin": "karin",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "pub": "npm publish --access public",
    "sort": "npx sort-package-json"
  },
  "dependencies": {
    "@karinjs/geturls": "^1.0.2",
    "form-data": "^4.0.6",
    "image-size": "^2.0.2",
    "qrcode": "^1.5.4",
    "silk-wasm": "^3.7.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@tencent-connect/qqbot-nodejs": "^1.0.4",
    "@types/express": "5.0.6",
    "@types/node": "^24.13.3",
    "@types/qrcode": "^1.5.6",
    "eslint": "^9.39.4",
    "neostandard": "^0.13.0",
    "node-karin": "1.16.3",
    "tsdown": "^0.22.13",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "karin": {
    "main": "src/index.ts",
    "apps": [
      "dist/apps"
    ],
    "ts-apps": [
      "src/apps"
    ],
    "static": [
      "resources"
    ],
    "files": [
      "config",
      "data",
      "resources"
    ],
    "ts-web": "src/web.config.ts",
    "web": "dist/web.config.js"
  }
}